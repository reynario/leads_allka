# =======================================================================
# Sistema de Leads Allka — variáveis de ambiente
# Copie para .env e preencha os valores. NUNCA comite o .env.
# =======================================================================

# --- Banco (Supabase Postgres) -----------------------------------------
# Pegue em: Supabase > Project Settings > Database > Connection string > URI
# Substitua "postgres://" por "postgresql+asyncpg://".
DATABASE_URL=postgresql+asyncpg://postgres:<senha>@db.<ref>.supabase.co:5432/postgres

# --- OpenAI -------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Meta (Facebook Graph API) -----------------------------------------
META_ACCESS_TOKEN=

# --- Apify (Instagram) -------------------------------------------------
APIFY_TOKEN=
APIFY_INSTAGRAM_ACTOR=apify/instagram-profile-scraper

# --- Redrive ------------------------------------------------------------
REDRIVE_API_TOKEN=
REDRIVE_BASE_URL=https://api.redrive.com.br

# --- Bitrix24 -----------------------------------------------------------
# URL completa do webhook (sem barra no final). Ex.:
# https://allka.bitrix24.com.br/rest/1/abcdef1234567890
BITRIX_WEBHOOK_URL=
BITRIX_SOURCE_ID=REDRIVE_IA

# --- Operacao -----------------------------------------------------------
ADMIN_TOKEN=troque-este-token

# --- UI / Auth (login da interface web) --------------------------------
# Gere uma string aleatoria longa para SESSION_SECRET (ex.: openssl rand -hex 32)
SESSION_SECRET=troque-este-secret-aleatorio-longo
SESSION_COOKIE_NAME=leads_allka_session
SESSION_MAX_AGE_SECONDS=28800

# Admin criado automaticamente no primeiro start (se a tabela users estiver vazia).
# Depois de criado, voce pode trocar a senha pela UI.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=Admin

SCHEDULER_ENABLED=true
PLAYWRIGHT_ENABLED=false
GOOGLE_ADS_ENABLED=false
DAILY_LEAD_BATCH_SIZE=20
DAILY_JOB_HOUR=8
DAILY_JOB_MINUTE=0
MAX_RETRY_COUNT=3
TZ=America/Sao_Paulo

# --- Domínio (Traefik) -------------------------------------------------
APP_DOMAIN=allkaleads.rndigitalmidia.com.br
TRAEFIK_NETWORK=RNNet
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencryptresolver
